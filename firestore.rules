rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Leitura pública — necessária para TelaHome (contagens e eventos)
    // Escrita apenas autenticada — todos os fluxos criam Firebase Auth antes de gravar
    match /atletas/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /equipes/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /inscricoes/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Resultados são públicos por natureza esportiva
    match /resultados/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // State: eventos e branding lidos publicamente na TelaHome
    // Histórico de ações também está aqui — sem PII sensível, apenas IDs e nomes de ações
    match /state/{id} {
      allow read: if true;
      allow write: if request.auth != null || id == "atl_sol_equipe";
    }

    // ── EVENTOS ──────────────────────────────────────────────────────────────
    // Leitura pública — TelaHome exibe eventos sem login
    // Escrita apenas autenticada
    match /eventos/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Câmara de Chamada ────────────────────────────────────────────────────
    // Leitura e escrita: qualquer usuário autenticado
    match /chamada/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Medalhas ─────────────────────────────────────────────────────────────
    // Leitura e escrita: qualquer usuário autenticado
    match /medalhas/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Súmula de Juízes de Marcha ───────────────────────────────────────────
    // Leitura e escrita: qualquer usuário autenticado
    match /marchaJuizes/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Numeração de Peito ──────────────────────────────────────────────────
    // Leitura e escrita: qualquer usuário autenticado
    match /numeracaoPeito/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Atletas Usuários (contas de atleta) ─────────────────────────────────
    // Migrado de state/atl_atletas_usuarios para coleção individual
    match /atletasUsuarios/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

  }
}
