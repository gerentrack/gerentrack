{
  "rewrites": [
    {
      "source": "/competicao/:slug/resultados",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|Bot|WhatsApp|whatsapp|Telegram|telegram|facebookexternalhit|Googlebot|googlebot|bingbot|Bingbot|Twitterbot|twitterbot|Slackbot|Discordbot|LinkedInBot|Applebot|spider|Spider|crawler|Crawler).*" }
      ],
      "destination": "/api/og?slug=:slug"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/workbox-(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
